@startuml
left to right direction
skinparam componentStyle rectangle
skinparam shadowing false

component "index.ts" as INDEX
component "hooks.ts" as HOOKS
component "config.ts\nhost-permissions.ts\ncompress-permission.ts" as CONFIG
component "state/*\nmessage-ids.ts\ntoken-utils.ts" as STATE
component "messages/*\nsubagents/*\nprotected-patterns.ts" as MSG
component "compress/*\nstrategies/*" as COMPRESS
component "commands/*" as CMDS
component "prompts/*" as PROMPTS
component "auth.ts\nupdate.ts\nlogger.ts\nui/*" as SUPPORT

INDEX --> CONFIG
INDEX --> HOOKS
INDEX --> SUPPORT

HOOKS --> STATE
HOOKS --> MSG
HOOKS --> COMPRESS
HOOKS --> CMDS
HOOKS --> PROMPTS

MSG --> STATE
COMPRESS --> STATE
COMPRESS --> MSG
CMDS --> STATE
CMDS --> MSG
PROMPTS --> STATE
PROMPTS --> COMPRESS
SUPPORT --> STATE
SUPPORT --> CMDS
@enduml
