@startuml
left to right direction
skinparam componentStyle rectangle
skinparam shadowing false

component "compress/index.ts" as ENTRY
component "pipeline.ts" as PIPE
component "search.ts" as SEARCH
component "range.ts\nmessage.ts\nrange-utils.ts\nmessage-utils.ts" as PLAN
component "protected-content.ts" as PROTECT
component "state.ts\ntiming.ts" as APPLY
component "strategies/*" as STRATEGY
component "state/*" as STATE
component "messages/*" as MSG
component "prompts/*" as PROMPTS

ENTRY --> PIPE
PIPE --> SEARCH
PIPE --> STRATEGY
PIPE --> STATE

PLAN --> SEARCH
PLAN --> PROTECT
PLAN --> APPLY
PLAN --> MSG
PLAN --> STATE
PLAN --> PROMPTS

APPLY --> STATE
APPLY --> MSG

@enduml
